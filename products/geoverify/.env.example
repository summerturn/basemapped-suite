# ============================================
# GeoVerify Environment Variables
# ============================================

# Database
POSTGRES_USER=geoverify
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=geoverify
DATABASE_URL=postgresql+asyncpg://geoverify:change-me-in-production@postgres:5432/geoverify

# Cache / Queue
REDIS_URL=redis://redis:6379/0

# API
SECRET_KEY=super-secret-jwt-signing-key-change-in-production
ENVIRONMENT=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000

# Fly.io (deployment)
FLY_API_TOKEN=

# PyPI (trusted publishing via OIDC — no token needed in CI)
# Set up at: https://pypi.org/manage/account/publishing/

# Optional: Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
